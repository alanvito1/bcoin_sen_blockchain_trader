# ==========================================
#   BLOCKCHAIN AUTO-TRADER - CONFIGURAÇÃO (EXEMPLO)
# ==========================================

# --- CREDENCIAIS CRÍTICAS ---
# Sua chave privada (NUNCA compartilhe este arquivo com a chave preenchida!)
PRIVATE_KEY=SUA_CHAVE_PRIVADA_AQUI

# --- CONFIGURAÇÕES DE REDE (RPCs) ---
# Opcional: Use RPCs privadas para maior velocidade e segurança contra MEV
# POLYGON_RPC=https://polygon-rpc.com
# BSC_RPC=https://bsc-dataseed.binance.org/

# Chaves de API para verificar status de transações no explorador (Opcional)
POLYGONSCAN_API_KEY=SUA_API_KEY_AQUI
BSCSCAN_API_KEY=SUA_API_KEY_AQUI

# --- PARÂMETROS GERAIS ---
# DRY_RUN=true: Simula as operações sem enviar transações reais
DRY_RUN=true
# Slippage aceitável (1.0 = 1%)
SLIPPAGE=1.0

# --- JANELAS DE EXECUÇÃO ---
# O bot sorteia dois minutos aleatórios a cada hora dentro destes intervalos
WINDOW1_MIN=15
WINDOW1_MAX=29
WINDOW2_MIN=45
WINDOW2_MAX=59

# --- ESTRATÉGIA A (MA21 - 30m) ---
STRATEGY_A_ENABLED=true
TIME_FRAME_A=30
MA_PERIOD_A=21
BUY_AMOUNT_A=3.0   # Valor em Native (BNB/POL) para comprar
SELL_AMOUNT_A=1.0  # Valor do Token para vender
STRATEGY_A_BUY_ENABLED=true
STRATEGY_A_SELL_ENABLED=true
# Habilita/Desabilita tokens específicos para esta estratégia
STRATEGY_A_BCOIN_ENABLED=true
STRATEGY_A_SEN_ENABLED=true

# --- ESTRATÉGIA B (MA21 - 4h) ---
STRATEGY_B_ENABLED=true
TIME_FRAME_B=4
MA_PERIOD_B=21
BUY_AMOUNT_B=4.0
SELL_AMOUNT_B=1.0
STRATEGY_B_BUY_ENABLED=true
STRATEGY_B_SELL_ENABLED=true
# Habilita/Desabilita tokens específicos para esta estratégia
STRATEGY_B_BCOIN_ENABLED=true
STRATEGY_B_SEN_ENABLED=true
