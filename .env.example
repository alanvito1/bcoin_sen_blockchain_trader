# Banco e Fila
DATABASE_URL="postgresql://user:password@localhost:5432/autotrader?schema=public"
REDIS_URL="redis://localhost:6379"

# Chave Mestra do Servidor (Necessária para AES-256-GCM)
# Gere uma chave de 32 bytes (256 bits) em hex ou base64
ENCRYPTION_KEY="sua_chave_secreta_de_32_bytes_aqui"

# Telegram
TELEGRAM_BOT_TOKEN="token_do_botfather"
TELEGRAM_BOT_USERNAME="@seu_bot_username"

# QA / UserBot (MTProto)
# Obtenha API_ID e API_HASH em https://my.telegram.org
TELEGRAM_API_ID="123456"
TELEGRAM_API_HASH="abcdef123456"
# A string será gerada na primeira execução do script de teste
QA_SESSION_STRING=""
