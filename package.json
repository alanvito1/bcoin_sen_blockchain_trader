{
  "name": "blockchain-trader",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev:bot": "nodemon src/bot/index.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate:local": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5433/autotrader?schema=public npx prisma migrate dev",
    "tools:clear-stuck": "node tools/clear-stuck.js",
    "tools:find-pools": "node tools/find_pools.js",
    "tools:check-router": "node tools/check-router.js",
    "test:db": "node test/db-check.js",
    "test:balances": "node test/testMultiChainBalances.js",
    "test:audit": "node test/wallet_audit.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@telegraf/session": "^2.0.0-beta.7",
    "axios": "^1.13.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "node-cron": "^4.2.1",
    "ta-math": "^1.0.49",
    "winston": "^3.19.0"
  },
  "bin": "index.js",
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "src/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "build"
  },
  "devDependencies": {
    "@prisma/client": "^6.3.0",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.71.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "prisma": "^6.3.0",
    "proxyquire": "^2.1.3",
    "telegraf": "^4.16.3"
  }
}
