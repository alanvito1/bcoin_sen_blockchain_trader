# 🌐 Production Environment Variables Example
# Copy this file to .env on your VPS and fill in the secrets.

# Node Configuration
NODE_ENV=production
PORT=3000

# Database (Supabase / Managed Postgres)
# Use the "Connection String" (Transaction pooler recommended: port 6543)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Redis (Upstash / Managed Redis)
# Use the "Redis URL" (URL)
REDIS_URL="redis://default:[YOUR_PASSWORD]@[YOUR_ENDPOINT]:6379"

# Telegram Configuration
TELEGRAM_BOT_TOKEN="[YOUR_TELEGRAM_BOT_TOKEN]"
ADMIN_CHAT_ID="[YOUR_CHAT_ID]"

# Blockchain / Wallet Private Keys (BE EXTREMELY CAREFUL)
# It is recommended to use a dedicated wallet with only the necessary balance.
WALLET_PRIVATE_KEY="[YOUR_PRIVATE_KEY]"
RPC_URL="[YOUR_RPC_URL]"

# Strategy Settings
MAX_TRADES_PER_ORDER=2
SLIPPAGE_TOLERANCE=0.5
