generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String         @id @default(uuid())
  telegramId            BigInt         @unique
  username              String?
  credits               Int            @default(0)
  subscriptionExpiresAt DateTime?
  isActive              Boolean        @default(true)
  stripeCustomerId      String?        @unique
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  hasAcceptedTerms      Boolean        @default(false)
  notifyBalances        Boolean        @default(true)
  notifySteps           Boolean        @default(true)
  notifyTrades          Boolean        @default(true)
  referralCode          String?        @unique
  referralPayoutAddress String?
  referredById          String?
  referralBalanceBCOIN  Float          @default(0.0)
  referralBalanceSEN    Float          @default(0.0)
  referralBalanceUSDT   Float          @default(0.0)
  xp                    Int            @default(0)
  level                 Int            @default(1)
  commissionRate        Float          @default(0.10)
  tradeConfigs          TradeConfig[]
  tradeHistory          TradeHistory[]
  commissionLogs        CommissionLog[] @relation("ReferralRewards")
  referredBy            User?          @relation("Referral", fields: [referredById], references: [id])
  referrals             User[]         @relation("Referral")
  wallet                Wallet?
  supportTickets        SupportTicket[]
}

model CommissionLog {
  id          String   @id @default(uuid())
  referrerId  String
  buyerId     String
  amountUSD   Float
  commission  Float
  asset       String
  txHash      String
  createdAt   DateTime @default(now())
  referrer    User     @relation("ReferralRewards", fields: [referrerId], references: [id])
}

model Session {
  id   String @id @default(uuid())
  key  String @unique
  data String
}

model Wallet {
  id                  String @id @default(uuid())
  userId              String @unique
  publicAddress       String
  encryptedPrivateKey String
  iv                  String
  authTag             String
  network             String @default("POLYGON")
  user                User   @relation(fields: [userId], references: [id])

  @@index([publicAddress])
}

model TradeConfig {
  id                  String  @id @default(uuid())
  userId              String
  tokenPair           String
  buyAmountA          Float   @default(10.0)
  sellAmountA         Float   @default(5.0)
  buyAmountB          Float   @default(4.0)
  sellAmountB         Float   @default(1.0)
  slippage            Float   @default(1.0)
  strategy30m         Boolean @default(true)
  strategy4h          Boolean @default(true)
  window1Min          Int     @default(15)
  window1Max          Int     @default(29)
  window2Min          Int     @default(45)
  window2Max          Int     @default(59)
  isOperating         Boolean @default(false)
  network             String  @default("BSC")
  intervalMinutes     Int     @default(60)
  maPeriodA           Int     @default(21)
  maPeriodB           Int     @default(21)
  rsiEnabled          Boolean @default(false)
  rsiPeriod           Int     @default(14)
  scheduleMode        String  @default("window")
  timeframeA          String  @default("30m")
  timeframeB          String  @default("4h")
  antiSandwichEnabled Boolean @default(false)
  dryRun              Boolean   @default(false)
  lastOperationAt     DateTime?
  lastOperationWindow Int?
  antiRugEnabled      Boolean   @default(false)
  autoSellEnabled     Boolean   @default(false)
  priorityMode        String    @default("Aggressive")
  user                User      @relation(fields: [userId], references: [id])

  @@unique([userId, network, tokenPair])
}

model TradeHistory {
  id           String   @id @default(uuid())
  userId       String
  txHash       String?
  type         String
  status       String
  amount       Float
  price        Float
  feeUsed      Float
  errorMessage String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
}

model PriceTick {
  id        String   @id @default(uuid())
  symbol    String
  network   String
  price     Float
  timestamp DateTime @default(now())

  @@index([symbol, network, timestamp])
}

model CustomToken {
  id        String   @id @default(uuid())
  network   String
  address   String   @unique
  symbol    String
  name      String?
  decimals  Int      @default(18)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([network, address])
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  category  String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model PayoutLog {
  id           String   @id @default(uuid())
  buyerId      String
  referrerId   String?
  network      String
  amountGross  Float
  gasDeducted  Float    @default(0.0)
  adminNet     Float
  referrerNet  Float    @default(0.0)
  payoutTxHash String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
}

model SystemSecret {
  id             String @id @default(uuid())
  key            String @unique
  encryptedValue String
  iv             String
  authTag        String
}
